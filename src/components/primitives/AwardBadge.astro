---
interface Props {
    award: string;
    label?: string;
    class?: string;
}

const { award, label, class: className } = Astro.props;
const text = label ? `${label}: ${award}` : award;
---

<p class:list={["award-badge", className]}>
    <span aria-hidden="true">🏆</span>
    <span>{text}</span>
</p>

<style>
    .award-badge {
        display: inline-flex;
        align-items: center;
        gap: 0.5rem;
        justify-self: start;
        width: fit-content;
        max-width: 100%;
        border-radius: 9999px;
        background: color-mix(in srgb, var(--color-accent) 10%, transparent);
        padding: 0.25rem 0.75rem;
        color: var(--color-accent);
        font-size: var(--text-caption);
        font-weight: 600;
        line-height: 1.4;
    }
</style>
