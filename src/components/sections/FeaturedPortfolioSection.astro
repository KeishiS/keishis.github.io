---
import { useTranslations } from "@/i18n/utils";
import { type Profile, getFeaturedPortfolios } from "@/lib/siteData";
import PortfolioSection from "@/components/sections/PortfolioSection.astro";

interface Props {
    lang: string;
    profile: Profile;
}

const { lang, profile } = Astro.props;
const t = useTranslations(lang as any);
const featuredPortfolios = getFeaturedPortfolios(profile);
---

{
    featuredPortfolios.length > 0 && (
        <PortfolioSection
            lang={lang}
            portfolios={featuredPortfolios}
            actionHref="/portfolio"
            actionLabel={t("portfolio.view_all")}
        />
    )
}
