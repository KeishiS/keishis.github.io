---
import { type SiteData } from "@/lib/siteData";
import { useTranslations } from "@/i18n/utils";
import SectionHeading from "@/components/primitives/SectionHeading.astro";
import PublicationCards from "@/components/patterns/PublicationCards.astro";

interface Props {
    lang: string;
    publications: SiteData["publications"];
}

const { lang, publications } = Astro.props;
const t = useTranslations(lang as any);
---

<section id="publications" class="section-shell">
    <SectionHeading title={t("publications.title")} centered={true} />

    <div class="space-y-12">
        {
            publications.journal_paper.length > 0 && (
                <div>
                    <h3 class="text-xl font-semibold mb-4 text-fg">
                        {t("publications.category.journal_papers")}
                    </h3>
                    <div class="card-stack">
                        <PublicationCards
                            publications={publications.journal_paper}
                            abstractToggleLabel={t("publications.show_abstract")}
                            externalLinkLabel={t("publications.open_link")}
                        />
                    </div>
                </div>
            )
        }
        {
            publications.refereed_international_conference.length > 0 && (
                <div>
                    <h3 class="text-xl font-semibold mb-4 text-fg">
                        {t("publications.category.refereed_international_conference")}
                    </h3>
                    <div class="card-stack">
                        <PublicationCards
                            publications={publications.refereed_international_conference}
                            abstractToggleLabel={t("publications.show_abstract")}
                            externalLinkLabel={t("publications.open_link")}
                        />
                    </div>
                </div>
            )
        }
        {
            publications.international_conference.length > 0 && (
                <div>
                    <h3 class="text-xl font-semibold mb-4 text-fg">
                        {t("publications.category.international_conference")}
                    </h3>
                    <div class="card-stack">
                        <PublicationCards
                            publications={publications.international_conference}
                            abstractToggleLabel={t("publications.show_abstract")}
                            externalLinkLabel={t("publications.open_link")}
                        />
                    </div>
                </div>
            )
        }
        {
            publications.domestic_workshop.length > 0 && (
                <div>
                    <h3 class="text-xl font-semibold mb-4 text-fg">
                        {t("publications.category.domestic_workshop")}
                    </h3>
                    <div class="card-stack">
                        <PublicationCards
                            publications={publications.domestic_workshop}
                            abstractToggleLabel={t("publications.show_abstract")}
                            externalLinkLabel={t("publications.open_link")}
                        />
                    </div>
                </div>
            )
        }
    </div>
</section>

<style>
    .card-stack {
        max-width: 880px;
        margin-inline: auto;
        width: 100%;
    }

    /* Mobile tweaks */
    @media (max-width: 768px) {
        .card-stack {
            max-width: 100%;
        }
    }
</style>
